rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (UID)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - role: string (required, 'faculty' or 'student')
    //   - displayName: string (optional)
    //
    // Collection: predictions
    // Document ID: predictionId
    // Fields:
    //   - studentData: map (required)
    //   - result: map (required)
    //   - createdBy: string (required, UID)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isFaculty() {
      return isAuthenticated() && getUserData().role == 'faculty';
    }

    function isStudent() {
      return isAuthenticated() && getUserData().role == 'student';
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['faculty', 'student'];
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                    request.resource.data.role == resource.data.role; // Role cannot be changed by user
    }

    match /predictions/{predictionId} {
      allow read: if isFaculty();
      allow write: if isFaculty();
    }
  }
}
